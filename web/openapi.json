          "user"
        ],
        "title": "Role",
        "type": "string"
      },
      "Ticker": {
        "properties": {
          "change_pct_24h": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Change Pct 24H",
