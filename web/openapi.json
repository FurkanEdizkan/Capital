          "price",
          "change_pct_24h",
          "quote_volume_24h"
        ],
        "title": "Ticker",
        "type": "object"
      },
      "TokenPair": {
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "refresh_token": {
            "title": "Refresh Token",
            "type": "string"
