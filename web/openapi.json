          },
          "mark_price": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Mark Price",
            "type": "string"
          },
          "next_funding_time": {
            "format": "date-time",
            "title": "Next Funding Time",
            "type": "string"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          }
        },
        "required": [
          "symbol",
          "funding_rate",
          "mark_price",
          "next_funding_time"
