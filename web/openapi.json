          "password"
        ],
        "title": "UserCreate",
        "type": "object"
      },
      "UserInfo": {
        "properties": {
          "role": {
            "title": "Role",
            "type": "string"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "role"
        ],
        "title": "UserInfo",
        "type": "object"
      },
      "UserRead": {
        "properties": {
          "id": {
            "title": "Id",
