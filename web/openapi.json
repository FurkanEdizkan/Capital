          "refresh_token"
        ],
        "title": "TokenPair",
        "type": "object"
      },
      "UserCreate": {
        "properties": {
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/Role",
            "default": "user"
          },
          "username": {
            "maxLength": 64,
            "minLength": 2,
