# Capital — reverse proxy and single entry point.
#
# Caddy serves the dashboard and proxies the API + WebSocket to the engine,
# so the browser sees one origin (no CORS).
#
# TLS is chosen by CAPITAL_TLS:
#   internal          — Caddy's private CA; for a Tailscale / LAN deploy with
#                       no public DNS (the default)
#   you@example.com   — an ACME contact email; Caddy obtains a public
#                       Let's Encrypt certificate for CAPITAL_HOSTNAME, for a
#                       cloud VM reachable on a real domain

{$CAPITAL_HOSTNAME:localhost} {
	tls {$CAPITAL_TLS:internal}

	encode gzip

	# Hardening headers — sent on every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# API and WebSocket traffic → the trading engine.
	@engine path /api/* /ws /ws/*
	handle @engine {
		reverse_proxy engine:8000
	}

	# Everything else → the web dashboard.
	handle {
		reverse_proxy web:80
	}
}
