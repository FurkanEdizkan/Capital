# Repo-wide ignores. Per-app ignores live in engine/.gitignore and web/.gitignore.

# Local environment / secrets — never commit
.env
.env.local
*.local

# PostgreSQL data volume + backups (see Deployment plan)
data/

# Node (root tooling — husky/commitlint)
node_modules/

# Python
__pycache__/
*.py[cod]

# OS / editor
.DS_Store
*.log

# Claude Code local session state — ignored, except shared project skills.
# Ignore .claude/ contents (settings.local.json, worktrees, session state...)
# but keep .claude/skills/ tracked so committed skills ship with the repo.
.claude/*
!.claude/skills/
