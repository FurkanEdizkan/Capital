# Capital engine — environment template. Copy to `.env` for local runs.
# All engine settings are prefixed CAPITAL_ (see config.py).

CAPITAL_ENVIRONMENT=development

# PostgreSQL connection (SQLAlchemy URL, psycopg3 driver).
# Default targets the local docker-compose Postgres; override for other hosts.
CAPITAL_DATABASE_URL=postgresql+psycopg://capital:capital@localhost:5432/capital

# Binance keys, JWT secret etc. are added in later phases.
